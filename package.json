{
  "name": "cbrowse",
  "version": "0.1.1",
  "license": "MIT",
  "type": "module",
  "description": "Connect MCP agents to a real signed-in browser with cookies, tabs, and page state intact.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cozythecoder/cBrowse.git"
  },
  "bugs": {
    "url": "https://github.com/Cozythecoder/cBrowse/issues"
  },
  "homepage": "https://github.com/Cozythecoder/cBrowse#readme",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "build:extension": "node ./scripts/build-extension.mjs",
    "dev:relay": "tsx src/relay/localRelay.ts",
    "dev:mcp:stdio": "tsx src/mcp/stdioServer.ts",
    "dev:mcp:http": "tsx src/mcp/httpServer.ts",
    "install:codex-skill": "tsx src/skills/installCodexSkill.ts",
    "release:local": "npm run build && npm run build:extension"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
